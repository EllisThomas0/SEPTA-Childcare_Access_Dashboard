<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>View All Bus Stops</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
    <style>
        .btn-custom {
            background-color: #1e6dc8;
            color:white;
        }
        .btn-custom:hover{
            background-color: #144b88ff;
            color: white;
        }
        body{
            background-color: #FFEEBE;
        }
    </style>

  </head>
  <body>

    <br>
    <figure>
        <div class="container">
        <h1><%= busStops[0].Mode %> Line <%= busLine %> Stops:</h1>   
        </div>
      </figure>

    <div class="container">
        <div class="row h-100">
          <!-- <div class="col-lg-4"></div> -->
          <div class="col-lg-4 text-center my-auto">
              <% if (busStops && busStops.length > 0) { %>
                <p>
                <table class="table table-bordered">
                    <th> Stop Name:</th>
                    <th> Line Direction: </th>
                    <th> Stop Number: </th>
                    <th> Select: </th>
                  <% busStops.forEach( (busStop) => { %>
                    <tr>
                        <td><%= busStop.StopName %></td>
                        <td> <%= busStop.DirectionN %> </td>
                        <td> <%= busStop.Sequence %> </td>
                      <td><a href="/1c_stopQuery?busStopId=<%= busStop.StopId %>" class="button button1">Select</a></td> 
                    </tr>                      
                  <% }) %>
                </table>
                </p>
              <% } else { %>
                <p>There are no user objects in the database.</p>
              <% } %>
    
            <p>
              <!-- <a href="/" class="btn btn-custom my-2">Back to Home</a> -->
            </p>
          </div>
    
          <!-- <div class="col-lg-4"></div> -->
        </div>
    
      </div>


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL" crossorigin="anonymous"></script>
  </body>
</html>


