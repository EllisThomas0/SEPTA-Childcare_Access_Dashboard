<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Search a Childcare Center</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
    <style>
        .btn-custom {
            background-color: #1e6dc8;
            color:white;
        }
        
        .btn-custom:hover{
            background-color: #144b88ff;
            color: white;
        }
        body{
            background-color: #FFEEBE;
        }
    </style>

  </head>
  <body>

    <br>
    <figure>
        <div class="container">
            <h1>Childcare Locations Found:</h1>
        </div>
      </figure>


      <div class="container">
          <div class="col-lg-4 text-center my-auto">
              <% if (childcareCenters && childcareCenters.length > 0) { %>
                <p>
                <table class="table table-bordered">
                    <th> Facility Name:</th>
                    <th> Provider Type:</th>
                    <th> Facility Street Address: </th>
                    <th> Facility City: </th>
                    <th> Facility Zip Code: </th>
                    <th> Contact: </th>
                    <th> Select: </th>

                  <% for (let i = 0; i < childcareCenters.length; i++) { %>
                    <tr>
                        <td><%= childcareCenters[i]["Facility Name"] %></td>
                        <td><%= childcareCenters[i]["Provider Type"] %></td>
                        <td> <%= childcareCenters[i]["Facility Address"] %> <br> <%= childcareCenters[i]["Facility Address (Continued)"] %></td>
                        <td><%= childcareCenters[i]["Facility City"] %></td>
                        <td><%= childcareCenters[i]["Facility Zip Code"] %></td>
                        <td><%= childcareCenters[i]["Facility Phone"] %></td>
                      <td><a href="/2c_ccQuery?ccId=<%=childcareCenters[i]._id%>" class="button button1">Select</a></td> 
                    </tr>                      
                  <% } %>
                </table>
                </p>
              <% } else { %>
                <p>There are no childcare centers containing your keyword(s).</p>
              <% } %>
        </div>
      </div>


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL" crossorigin="anonymous"></script>
  </body>
</html>