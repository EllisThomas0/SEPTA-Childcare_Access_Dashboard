<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Search for a Childcare Location</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
    <style>
        .btn-custom {
            background-color: #1e6dc8;
            color:white;
        }
        
        .btn-custom:hover{
            background-color: #144b88ff;
            color: white;
        }
        body{
            background-color: #FFEEBE;
        }
    </style>

  </head>
  <body>

    <br>
    <figure>
        <div class="container">
            <h1>Search for a Childcare Location</h1>
            <form action="/2b_ccFind" method="GET">
                <label for="ccSearchTerms">Enter one or more keyword that appear in the name of the childcare center, or leave empty to browse all locations:</label><br>
                <input type="text" class="form-control" id="ccSearchTerms" name="ccSearchTerms">
                <input type="submit" class="btn btn-custom my-2" value="Search">
                </form>
        </div>
      </figure>

        <!-- <td><a href="/ccFind" class="button button1">Directions</a></td>  -->



    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL" crossorigin="anonymous"></script>
  </body>
</html>


