<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>View All Bus Lines</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
  
  <style>
    .btn-custom {
        background-color: #1e6dc8;
        color:white;
    }
    .btn-custom:hover{
        background-color: #144b88ff;
        color: white;
    }
    body{
        background-color: #FFEEBE;
    }
  </style>
  
  <!-- <script type="text/javascript">
    function confirmDelete(username) {
      var answer = confirm("Are sure you want to delete " + username + "?")
      if (answer){
        window.location = "/deleteUser?username=" + username;
      }
    }
    </script> -->
</head>
<body>

    <figure class="text-center">
        <h1>SEPTA Transit Lines:</h1>
      </figure>

  <div class="container">
    <div class="row h-100">
      <div class="col-lg-4"><!-- this is just here to center the next column --></div>
      <div class="col-lg-4 text-center my-auto">
          <% if (busLines && busLines.length > 0) { %>
            <p>
            <table class="table table-bordered">
                <th> Line Name: </th>
                <th> Transit Mode: </th>
                <th> Stops: </th>
                
              <% busLines.forEach( (busLine) => { %>
                <tr>      
                  <td>Line: <%= busLine._id %></td>
                  <td> <%= busLine.Mode %></td>
                  <td><a href="/1b_allStops?LineAbbr=<%= busLine._id %>" class="button button1">View Stops</a></td> 
                </tr>
              <% }) %>
            </table>
            </p>
          <% } else { %>
            <p>There are no bus lines in the database.</p>
          <% } %>

        <p>
          <!-- <a href="/" class="btn btn-custom my-2">Back to Home</a> -->
        </p>
      </div>

      <div class="col-lg-4"><!-- this is just here to center the previous column --></div>
    </div>

  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL" crossorigin="anonymous"></script>
</body>
</html>
