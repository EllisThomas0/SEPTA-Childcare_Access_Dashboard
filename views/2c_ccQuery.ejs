<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>View Childcare Center Info</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
    <style>
        .btn-custom {
            background-color: #1e6dc8;
            color:white;
        }
        
        .btn-custom:hover{
            background-color: #144b88ff;
            color: white;
        }
        body{
            background-color: #FFEEBE;
        }
    </style>

  </head>
  <body>

    <br>
    <figure>
        <div class="container">
            <h1>Childcare Center Info & Closest Transit Stops</h1>
            Facility Name: <b><%= childcareCenter["Facility Name"] %></b>
            <br>
            Provider Type: <b><%= childcareCenter["Provider Type"] %></b>
            <br>
            Facility Address: <b><%= childcareCenter["Facility Address"] %> <%= childcareCenter["Facility Address (Continued)"] %></b>
            <br>
            Facility City: <b><%= childcareCenter["Facility City"] %></b>
            <br>
            Facility State: <b><%= childcareCenter["Facility State"] %></b>
            <br>
            Facility Zip Code: <b><%= childcareCenter["Facility Zip Code"] %></b>
            <br>
            Facility Phone: <b><%= childcareCenter["Facility Phone"] %></b>
            <br>
            Facility Email: <b><%= childcareCenter["Facility Email"] %></b>
            <br>
    
            <h1>Closest Transit Stops:</h1>
        </div>
      </figure>

      <!-- <figure></figure> -->
      <!-- <h1>Childcare Locations Within .5 Miles:</h1> -->


      <div class="container">
          <div class="col-lg-4 text-center my-auto">
              <% if (busStops && busStops.length > 0) { %>
                <p>
                <table class="table table-bordered">
                    <th> Stop Name:</th>
                    <th> Distance to Stop (miles):</th>
                    <th> Stop Line: </th>
                    <th> Transit Mode: </th>
                    <th> Line Direction:</th>
                    <th> Directions: </th>
                  <% for (let i = 0; i < distances.length; i++) { %>
                    <tr>
                        <td><%= busStops[i].StopName %></td>
                        <td> <%= distances[i] %> </td>
                        <td><%= busStops[i].LineAbbr %></td>
                        <td><%= busStops[i].Mode %></td>
                        <td> <%= busStops[i].DirectionN %> </td>
                      <td><a href="https://www.google.com/maps/dir/?api=1&origin=<%=givenCCLat%>,<%=givenCCLon%>&destination=<%=latVals[i]%>,<%=lonVals[i]%>&travelmode=walking" class="button button1">Directions</a></td> 
                    </tr>                      
                  <% } %>
                </table>
                </p>
              <% } else { %>
                <p>There are no transit stops within 0.5 miles.</p>
              <% } %>
        </div>
      </div>


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL" crossorigin="anonymous"></script>
  </body>
</html>


